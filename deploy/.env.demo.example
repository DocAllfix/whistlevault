# DEMO environment (branch demo-sales) — copy to deploy/.env.demo on the server.
# NOT for production. Reusable, throwaway: wipe volumes to reset.

# --- Postgres (isolated demo DB) -------------------------------------------
POSTGRES_USER=wb
POSTGRES_PASSWORD=change-me-demo-db-password
POSTGRES_DB=whistleblower

# --- Receipt pepper (server-side HMAC secret, never in the DB) --------------
# Generate with: openssl rand -hex 32
RECEIPT_PEPPER=change-me-generate-with-openssl-rand-hex-32

# --- Demo provisioning (consumed by scripts/provision_demo.py) --------------
DEMO_BASE_DOMAIN=wbapp.dedyn.io
DEMO_COUNT=10

# --- SMTP (OPTIONAL for the demo) ------------------------------------------
# Leave blank to run without email notifications (everything else still works).
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_USERNAME=
SMTP_PASSWORD=
