# Production reverse proxy with automatic HTTPS (Let's Encrypt).
# Replace the domain placeholders per client. The public portal and the
# backoffice are served on SEPARATE hostnames; the backend API is never
# exposed directly.

# --- Public whistleblower portal -------------------------------------------
{$PUBLIC_DOMAIN} {
	encode gzip
	root * /srv/public
	# API calls proxied to the backend (same-origin → cookies/Bearer work).
	handle /api/* {
		reverse_proxy api:8000
	}
	# SPA fallback.
	handle {
		try_files {path} /index.html
		file_server
	}
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Cross-Origin-Opener-Policy "same-origin"
		# Public portal only: the voice-report field uses getUserMedia, so allow the
		# microphone here (the browser still prompts the user). Backoffice keeps it off.
		Permissions-Policy "geolocation=(), camera=(), microphone=(self)"
		# M2: CSP for the SPA. script-src 'self' (Vite emits external modules);
		# 'unsafe-inline' is needed only for inline STYLE attributes set at runtime
		# (framer-motion / driver.js), not for scripts. API is same-origin.
		# 'wasm-unsafe-eval' is required to instantiate the libsodium WebAssembly
		# (ZK crypto); it permits WASM compilation only, NOT general JS eval.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'"
	}
	# H3 / privacy: access logging stays OFF (Caddy default) so the reporter IP is
	# never written to disk. If you must enable `log`, strip request>remote_ip.
}

# --- Backoffice (handlers) --------------------------------------------------
# Restrict exposure: ideally behind VPN/SSO or an IP allow-list (see remote_ip).
{$BACKOFFICE_DOMAIN} {
	encode gzip
	root * /srv/backoffice
	# Example IP allow-list (uncomment and set ranges):
	# @blocked not remote_ip 10.0.0.0/8 192.168.0.0/16
	# respond @blocked 403
	handle /api/* {
		reverse_proxy api:8000
	}
	handle {
		try_files {path} /index.html
		file_server
	}
	header {
		Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		Cross-Origin-Opener-Policy "same-origin"
		Permissions-Policy "geolocation=(), camera=(), microphone=()"
		# M2: CSP for the SPA. script-src 'self' (Vite emits external modules);
		# 'unsafe-inline' is needed only for inline STYLE attributes set at runtime
		# (framer-motion / driver.js), not for scripts. API is same-origin.
		# 'wasm-unsafe-eval' is required to instantiate the libsodium WebAssembly
		# (ZK crypto); it permits WASM compilation only, NOT general JS eval.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'"
	}
	# H3 / privacy: access logging stays OFF (Caddy default) so the reporter IP is
	# never written to disk. If you must enable `log`, strip request>remote_ip.
}
