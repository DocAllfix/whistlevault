# Copy to deploy/.env.prod (per client) and fill in. NEVER commit the real file.
# Database (isolated per client)
POSTGRES_USER=wb
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=whistleblower

# Domains (separate hosts for public portal and backoffice)
PUBLIC_DOMAIN=segnalazioni.cliente.it
BACKOFFICE_DOMAIN=gestione.cliente.it

# Initial admin password (provisioned on first start; change after login)
ADMIN_PASSWORD=change-me-admin

# SMTP for notifications
SMTP_HOST=smtp.cliente.it
SMTP_PORT=587
SMTP_FROM=no-reply@cliente.it
