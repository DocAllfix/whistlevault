# Copy to deploy/.env.prod (per client) and fill in. NEVER commit the real file.
# Database (isolated per client)
POSTGRES_USER=wb
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=whistleblower

# Domains — sottodomini sul dominio-brand whistlevault.it (via DNS wildcard).
# Sostituisci "acme" col nome del cliente.
PUBLIC_DOMAIN=acme.whistlevault.it
BACKOFFICE_DOMAIN=acme-gestione.whistlevault.it

# Initial admin password (provisioned on first start; change after login)
ADMIN_PASSWORD=change-me-admin

# H2 — Receipt lookup pepper (HMAC key). MUST be a strong UNIQUE random secret
# per tenant; the app refuses to boot in production if left as a placeholder.
# Generate e.g. with:  openssl rand -hex 32
RECEIPT_PEPPER=change-me-receipt-pepper

# SMTP for notifications (real relays require auth over STARTTLS)
SMTP_HOST=smtp.cliente.it
SMTP_PORT=587
SMTP_FROM=no-reply@cliente.it
SMTP_USERNAME=
SMTP_PASSWORD=
