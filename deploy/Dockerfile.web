# Builds both SPAs and serves them via Caddy (automatic HTTPS + reverse proxy).
FROM node:22-alpine AS build
WORKDIR /build

# Public portal
COPY frontend/public/package.json frontend/public/package-lock.json ./public/
RUN cd public && npm ci
COPY frontend/public ./public
RUN cd public && npm run build

# Backoffice
COPY frontend/backoffice/package.json frontend/backoffice/package-lock.json ./backoffice/
RUN cd backoffice && npm ci
COPY frontend/backoffice ./backoffice
RUN cd backoffice && npm run build

FROM caddy:2-alpine
COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY --from=build /build/public/dist /srv/public
COPY --from=build /build/backoffice/dist /srv/backoffice
